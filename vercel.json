{
  "buildCommand": "npm install && NODE_ENV=production vite build --config vite.vercel.config.ts && cp -r client/src/components/ui dist/public/components/",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/summaries",
      "destination": "/api/summaries.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "${VITE_SUPABASE_URL}",
    "VITE_SUPABASE_ANON_KEY": "${VITE_SUPABASE_ANON_KEY}",
    "VITE_API_URL": "https://${VERCEL_URL}",
    "GEMINI_API_KEY": "${GEMINI_API_KEY}",
    "YOUTUBE_API_KEY": "${YOUTUBE_API_KEY}",
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}