{
  "buildCommand": "npm install && npm install --prefix client && cp theme.json client/ && cd client && vite build --config ../vite.vercel.config.ts",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "${VITE_SUPABASE_URL}",
    "VITE_SUPABASE_ANON_KEY": "${VITE_SUPABASE_ANON_KEY}",
    "VITE_API_URL": "https://${VERCEL_URL}",
    "NODE_ENV": "production"
  }
}