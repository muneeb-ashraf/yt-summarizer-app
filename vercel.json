{
  "buildCommand": "npm install && NODE_ENV=production vite build --config vite.vercel.config.ts && cp -r client/src/components/ui dist/public/components/",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "https://<your-supabase-project-id>.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "your-supabase-anon-key",
    "VITE_API_URL": "https://<your-replit-app-name>.repl.co",
    "GEMINI_API_KEY": "your-gemini-api-key",
    "YOUTUBE_API_KEY": "your-youtube-api-key",
    "NODE_ENV": "production"
  }
}